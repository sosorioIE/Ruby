<h1>Iniciar sesión</h1>

<% if flash[:alert] %>
  <p style="color: red;"><%= flash[:alert] %></p> 
<% end %>

<%= form_tag login_path do %>
  <p>
    <%= label_tag :email %><br>
    <%= text_field_tag :email %>
  </p>

  <p>
    <%= label_tag :password %><br>
    <%= password_field_tag :password %>
  </p>

  <%= submit_tag "Iniciar sesión" %>
<% end %>