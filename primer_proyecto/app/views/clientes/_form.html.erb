<%= form_with(model: cliente, local: true) do |form| %>
  <% if cliente.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(cliente.errors.count, "error") %> prohibited this cliente from being saved:</h2>

      <ul>
      <% cliente.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :nombre %>
    <%= form.text_field :nombre, id: :cliente_nombre %>
  </div>

  <div class="field">
    <%= form.label :apellidos %>
    <%= form.text_field :apellidos, id: :cliente_apellidos %>
  </div>

  <div class="field">
    <%= form.label :direccion %>
    <%= form.text_area :direccion, id: :cliente_direccion %>
  </div>

  <div class="field">
    <%= form.label :nif %>
    <%= form.number_field :nif, id: :cliente_nif %>
  </div>

  <div class="actions">
    <%= form.submit cliente.new_record? ? "Añadir Cliente" : "Actualizar Cliente" %>
  </div>
<% end %>
